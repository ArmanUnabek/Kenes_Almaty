# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=os_journal
DB_USER=os_user
DB_PASS=change_me

# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# Session
SESSION_LIFETIME=7200

# Pusher (realtime, optional)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu

# Email (notifications cron, optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# File uploads
UPLOAD_MAX_MB=10
