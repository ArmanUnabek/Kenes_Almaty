# Database Configuration
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=os_journal
DB_CHARSET=utf8mb4

# PostgreSQL Configuration (if using pgsql driver)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=os_journal

# Application Settings
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=info

# Cache Settings
CACHE_TTL=3600
CACHE_DRIVER=file

# Rate Limiting
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=3600

# File Upload Settings
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads/photos/

# Session Settings
SESSION_TIMEOUT=1800
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

# Cron Settings
# Секретный токен для запуска cron_deadlines.php через HTTP (?token=...)
CRON_TOKEN=

# CORS Settings
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# Pusher Settings (optional)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu

# Email Settings (optional)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
