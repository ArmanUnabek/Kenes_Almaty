# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=os_journal
DB_USER=os_user
DB_PASS=change_me

# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# Session (idle timeout in seconds — maps to SESSION_IDLE_TIMEOUT_SECONDS)
SESSION_LIFETIME=7200

# Pusher (realtime, optional)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu

# Email (notifications cron, optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# File uploads
UPLOAD_MAX_MB=10

# CORS (comma-separated origins, optional)
ALLOWED_ORIGINS=

# Cron web trigger (optional, for cron_deadlines.php via HTTP)
CRON_TOKEN=

# Health check (UptimeRobot, etc.) — GET /api/health.php?token=...
# If empty, only admin session can access health endpoint
HEALTH_CHECK_TOKEN=

# KazLLM (опционально) — перевод пользовательского контента через Ollama/llama.cpp
# См. docs/KAZLLM.md
KAZLLM_ENABLED=false
KAZLLM_API_URL=http://127.0.0.1:11434
KAZLLM_MODEL=kazllm
KAZLLM_PROVIDER=ollama
KAZLLM_TIMEOUT=120

# Moderators may email only regional users/members or these domains (comma-separated)
NOTIFY_ALLOWED_DOMAINS=gov.kz

